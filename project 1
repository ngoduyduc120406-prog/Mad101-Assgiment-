def knight_moves(m, n, i, j):
    moves = [(2,1),(2,-1),(-2,1),(-2,-1),
             (1,2),(1,-2),(-1,2),(-1,-2)]
    res = []

    for dx, dy in moves:
        x, y = i + dx, j + dy
        if 0 <= x < m and 0 <= y < n:
            res.append((x,y))
    return res


def min_knight_sum(A):
    m, n = len(A), len(A[0])
    best = float('inf')
    pos = None

    for i in range(m):
        for j in range(n):
            for x,y in knight_moves(m,n,i,j):
                s = A[i][j] + A[x][y]
                if s < best:
                    best = s
                    pos = ((i,j),(x,y))

    return pos, best


def value(i, j):
    return ((-1)**i)*(i*i - i) + ((-1)**j)*(j*j - j + 1)


def f(n):
    best = -10**18

    for i in range(n):
        for j in range(n):
            for x,y in knight_moves(n,n,i,j):
                s = value(i,j) + value(x,y)
                best = max(best, s)

    return best % 7001


