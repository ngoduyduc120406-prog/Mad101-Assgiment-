def product(M, N):
    return [
        [M[0][0]*N[0][0] + M[0][1]*N[1][0],
         M[0][0]*N[0][1] + M[0][1]*N[1][1]],
        [M[1][0]*N[0][0] + M[1][1]*N[1][0],
         M[1][0]*N[0][1] + M[1][1]*N[1][1]]
    ]


def add(M, N):
    return [[M[i][j] + N[i][j] for j in range(2)] for i in range(2)]


def scalar_mult(k, M):
    return [[k*M[i][j] for j in range(2)] for i in range(2)]


def compute(n):
    A = [[3,-4],[2,-1]]
    B = [[2,-3],[1,4]]

    An = [[1,0],[0,1]]
    Bn = [[0,0],[0,0]]

    for _ in range(n):
        newA = add(product(An, A), scalar_mult(13, product(Bn, B)))
        newB = add(product(An, B), product(Bn, A))
        An, Bn = newA, newB

    return An, Bn


